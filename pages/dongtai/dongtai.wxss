page {
  background-color: #faf7f2;
  height: 100%;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
  flex-shrink: 0;
  background: #faf7f2;
}

.nav-bar {
  flex-shrink: 0;
  padding: 8rpx 36rpx 20rpx;
  background: #faf7f2;
}

.nav-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #2a2220;
  letter-spacing: -0.5rpx;
  display: block;
}

.fab-publish {
  position: fixed;
  right: 28rpx;
  bottom: calc(196rpx + constant(safe-area-inset-bottom));
  bottom: calc(196rpx + env(safe-area-inset-bottom));
  z-index: 95;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #a8483c;
  box-shadow: 0 12rpx 32rpx rgba(168, 72, 60, 0.38), 0 0 0 1rpx rgba(255, 255, 255, 0.12) inset;
}

.fab-publish-hover {
  opacity: 0.92;
  transform: scale(0.96);
}

.fab-publish-plus {
  font-size: 40rpx;
  font-weight: 300;
  color: #ffffff;
  line-height: 1;
}

.fab-publish-txt {
  font-size: 22rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1;
}

.content-scroll {
  flex: 1;
  height: 0;
  box-sizing: border-box;
  overflow: hidden;
}

.scroll-bottom-gap {
  width: 100%;
  box-sizing: content-box;
  height: 288rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.section-hosts {
  padding: 0 28rpx 8rpx;
}

.section-hosts-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-hosts-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #2a2220;
}

.section-hosts-more {
  font-size: 26rpx;
  font-weight: 600;
  color: #a8483c;
}

.hosts-scroll {
  width: 100%;
  white-space: nowrap;
}

.hosts-row {
  display: inline-flex;
  gap: 36rpx;
  padding: 4rpx 4rpx 8rpx;
}

.host-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 128rpx;
  flex-shrink: 0;
}

.host-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  display: block;
  border: 3rpx solid #c46a5c;
  box-sizing: border-box;
}

.host-name {
  margin-top: 14rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #3d2f2c;
  text-align: center;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feed-list {
  padding: 16rpx 28rpx 24rpx;
}

.post-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx 28rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(42, 34, 32, 0.06);
}

.post-head {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.post-head-profile {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.link-hover {
  opacity: 0.75;
}

.post-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: block;
}

.post-meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.post-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #3d2f2c;
}

.post-time {
  font-size: 24rpx;
  color: #9a928a;
}

.follow-btn {
  flex-shrink: 0;
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
  background: #a8483c;
  border: 2rpx solid #a8483c;
}

.follow-btn.followed {
  color: #7a726a;
  background: #f0ebe4;
  border-color: #e0d8cf;
}

.post-media {
  position: relative;
  width: 100%;
  height: 360rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.post-image {
  width: 100%;
  height: 100%;
  display: block;
}

.gather-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(42, 34, 32, 0.5);
  font-size: 22rpx;
  font-weight: 600;
  color: #ffffff;
}

.post-location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 18rpx;
}

.location-icon {
  font-size: 26rpx;
  line-height: 1;
}

.location-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #a8483c;
}

.post-body {
  display: block;
  font-size: 28rpx;
  line-height: 1.65;
  color: #3d2f2c;
  margin-bottom: 28rpx;
}

.post-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.action-left {
  display: flex;
  align-items: center;
  gap: 28rpx;
  flex-wrap: wrap;
}

.action-item {
  font-size: 26rpx;
  color: #7a726a;
  font-weight: 600;
}

.action-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.reply-stack {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.reply-face {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 3rpx solid #ffffff;
  box-sizing: border-box;
  flex-shrink: 0;
}

.reply-extra {
  font-size: 24rpx;
  font-weight: 700;
  color: #7a726a;
}

/* 与首页一致的底部导航 */
.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  box-sizing: border-box;
  min-height: 176rpx;
  background: #ffffff;
  border-radius: 52rpx 52rpx 0 0;
  box-shadow: 0 -8rpx 36rpx rgba(74, 61, 57, 0.08);
  padding: 20rpx 16rpx calc(14rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
}

.tab-bar-inner {
  position: relative;
  width: 100%;
}

.tab-highlight {
  position: absolute;
  left: 0;
  bottom: 2rpx;
  z-index: 0;
  width: 20%;
  height: 124rpx;
  pointer-events: none;
  transition: transform 0.45s cubic-bezier(0.33, 1.12, 0.36, 1);
  will-change: transform;
}

.tab-highlight-inner {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 90%;
  height: 92%;
  max-width: 134rpx;
  transform: translate(-50%, -50%);
  box-sizing: border-box;
  background: linear-gradient(138deg, #e56d64 0%, #c44d44 38%, #b03d36 100%);
  box-shadow: 0 10rpx 28rpx rgba(196, 77, 68, 0.32), 0 0 0 1rpx rgba(255, 255, 255, 0.12) inset;
  animation: tab-flow-morph 4.5s ease-in-out infinite;
}

@keyframes tab-flow-morph {
  0%,
  100% {
    border-radius: 42% 58% 50% 50% / 50% 48% 52% 50%;
    transform: translate(-50%, -50%) scale(1);
  }
  33% {
    border-radius: 54% 46% 44% 56% / 46% 54% 50% 50%;
    transform: translate(-50%, -50%) scale(0.97);
  }
  66% {
    border-radius: 46% 54% 56% 44% / 52% 46% 48% 52%;
    transform: translate(-50%, -50%) scale(1.03);
  }
}

.tab-row {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  min-width: 0;
  padding-bottom: 12rpx;
}

.tab-item--active {
  padding-bottom: 12rpx;
}

.tab-item-hover {
  opacity: 0.88;
}

.tab-ico {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  transition: filter 0.32s ease, transform 0.35s cubic-bezier(0.33, 1.12, 0.36, 1);
}

.tab-item--active .tab-ico {
  transform: translateY(-2rpx);
}

.tab-ico--on {
  filter: brightness(0) invert(1);
}

.tab-txt {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #4a3d39;
  line-height: 1.15;
  transition: color 0.3s ease, transform 0.35s cubic-bezier(0.33, 1.12, 0.36, 1);
}

.tab-item--active .tab-txt {
  transform: translateY(-1rpx);
}

.tab-txt--on {
  color: #ffffff;
}
