page {
  background-color: #faf7f2;
  height: 100%;
}

.page {
  height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(140rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.hero {
  position: relative;
  width: 100%;
  height: 400rpx;
}

.cover {
  width: 100%;
  height: 100%;
  display: block;
}

.badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.badge--ok {
  background: #e8f5e9;
  color: #2e7d32;
}

.badge--wait {
  background: #fff8e1;
  color: #e65100;
}

.badge--end {
  background: rgba(255, 255, 255, 0.92);
  color: #616161;
}

.sheet {
  margin: -36rpx 24rpx 0;
  position: relative;
  z-index: 2;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 32rpx 28rpx 36rpx;
  box-shadow: 0 10rpx 40rpx rgba(42, 34, 32, 0.08);
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #2a2220;
  margin-bottom: 24rpx;
  line-height: 1.35;
}

.row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.row-ico {
  font-size: 28rpx;
  width: 40rpx;
  text-align: center;
}

.row-txt {
  font-size: 28rpx;
  color: #5c534c;
}

.host {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 28rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #f3ebe3;
}

.host-av {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.host-info {
  flex: 1;
  min-width: 0;
}

.host-name {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #3d2f2c;
}

.host-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #7a726a;
}

.faces-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 20rpx;
}

.face {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid #ffffff;
  box-sizing: border-box;
}

.line {
  height: 1rpx;
  background: #f0ebe4;
  margin: 28rpx 0 24rpx;
}

.desc {
  font-size: 28rpx;
  line-height: 1.65;
  color: #5c534c;
}

.bottom-gap {
  height: 24rpx;
}

.foot {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  gap: 20rpx;
  padding: 16rpx 24rpx calc(16rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -6rpx 24rpx rgba(74, 61, 57, 0.08);
}

.foot-chat {
  width: 32%;
  flex-shrink: 0;
  text-align: center;
  padding: 24rpx 16rpx;
  border-radius: 20rpx;
  border: 2rpx solid #a8483c;
  font-size: 28rpx;
  font-weight: 700;
  color: #a8483c;
}

.foot-hover {
  opacity: 0.9;
}

.foot-primary {
  flex: 1;
  text-align: center;
  padding: 24rpx 16rpx;
  border-radius: 20rpx;
  background: #a8483c;
  font-size: 30rpx;
  font-weight: 800;
  color: #ffffff;
}

.foot-primary-hover {
  opacity: 0.93;
}

.apps-block {
  margin-top: 28rpx;
}

.apps-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #2a2220;
  margin-bottom: 16rpx;
}

.app-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0ebe6;
}

.app-av {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f5f0eb;
  flex-shrink: 0;
}

.app-name {
  flex: 1;
  font-size: 28rpx;
  color: #3d3530;
}

.app-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.app-btn {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.app-btn--ok {
  background: #a8483c;
  color: #fff;
}

.app-btn--no {
  background: #f5f0eb;
  color: #7a726a;
}

.app-btn-hover {
  opacity: 0.88;
}

.apps-empty {
  margin-top: 24rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 26rpx;
  color: #9a928a;
  background: #faf7f2;
  border-radius: 16rpx;
}
