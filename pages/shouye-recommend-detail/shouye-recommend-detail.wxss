page {
  background-color: #faf7f2;
  height: 100%;
}

.page {
  height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(140rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.hero {
  position: relative;
  width: 100%;
  height: 420rpx;
}

.cover {
  width: 100%;
  height: 100%;
  display: block;
}

.rating-chip {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  font-weight: 800;
  color: #3d2f2c;
}

.star {
  color: #c9a227;
  margin-right: 6rpx;
}

.sheet {
  margin: -40rpx 24rpx 0;
  position: relative;
  z-index: 2;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 32rpx 28rpx 28rpx;
  box-shadow: 0 10rpx 40rpx rgba(42, 34, 32, 0.08);
}

.name {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  color: #2a2220;
  line-height: 1.35;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.tag {
  background: #f5f3f1;
  color: #7a726a;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 18rpx;
  border-radius: 10rpx;
}

.price-row {
  margin-top: 20rpx;
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.price {
  color: #a8483c;
  font-size: 40rpx;
  font-weight: 800;
}

.unit {
  font-size: 22rpx;
  color: #7a726a;
}

.block {
  margin-top: 32rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #f0ebe6;
}

.block--last {
  padding-bottom: 8rpx;
}

.block-title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #3d2f2c;
  margin-bottom: 18rpx;
}

.row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.row-ico {
  font-size: 26rpx;
  width: 40rpx;
  flex-shrink: 0;
  text-align: center;
  margin-top: 2rpx;
}

.row-txt {
  flex: 1;
  font-size: 26rpx;
  color: #5c534c;
  line-height: 1.55;
}

.para {
  display: block;
  font-size: 28rpx;
  color: #5c534c;
  line-height: 1.65;
}

.dish {
  background: #faf7f2;
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #f0ebe6;
}

.dish:last-child {
  margin-bottom: 0;
}

.dish-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #2a2220;
  margin-bottom: 8rpx;
}

.dish-desc {
  display: block;
  font-size: 24rpx;
  color: #7a726a;
  line-height: 1.55;
}

.foot-gap {
  height: 24rpx;
}

.foot {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(250, 247, 242, 0) 0%, #faf7f2 28%);
  box-sizing: border-box;
}

.foot-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  background: #a8483c;
}
