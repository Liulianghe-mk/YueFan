page {
  background: #faf7f2;
  height: 100%;
}

.page {
  min-height: 100vh;
}

.scroll {
  height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 32rpx 0;
}

.hint {
  font-size: 24rpx;
  color: #7a726a;
  margin-bottom: 20rpx;
}

.meetup-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.meetup-card-hover {
  opacity: 0.92;
}

.meetup-card {
  background: #ffffff;
  padding: 24rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(42, 34, 32, 0.05);
  border: 1rpx solid #f0ebe6;
}

.avatar-box {
  position: relative;
  width: 110rpx;
  height: 110rpx;
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar.ring {
  border: 4rpx solid rgba(168, 72, 60, 0.28);
  box-sizing: border-box;
}

.v-badge {
  position: absolute;
  right: -2rpx;
  bottom: -2rpx;
  background: #7d5800;
  color: #ffffff;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #ffffff;
}

.meetup-body {
  flex: 1;
  margin-left: 24rpx;
  margin-right: 20rpx;
  min-width: 0;
}

.m-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #3d2f2c;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.m-info {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
}

.m-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  flex-wrap: nowrap;
}

.time-box {
  display: flex;
  align-items: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.m-icon.red {
  color: #a8483c;
}

.m-text {
  font-size: 24rpx;
  color: #7a726a;
}

.m-text.dark {
  color: #3d2f2c;
  font-weight: 600;
}

.count-badge {
  background: #f5f3f1;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #7a726a;
  font-weight: 700;
  white-space: nowrap;
}

.count-badge.active {
  background: rgba(168, 72, 60, 0.12);
  color: #a8483c;
}

.m-action {
  flex-shrink: 0;
}

.btn {
  padding: 16rpx 40rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

.primary-btn {
  background: #a8483c;
  color: #ffffff;
  border: 2rpx solid #a8483c;
}

.gray-btn {
  background: #eceae8;
  color: #7a726a;
}

.foot-gap {
  height: 48rpx;
}

.state {
  padding: 120rpx 48rpx;
  text-align: center;
}

.state-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #3d2f2c;
  margin-bottom: 12rpx;
}

.state-txt {
  display: block;
  font-size: 26rpx;
  color: #7a726a;
}

.state-btn {
  display: inline-block;
  margin-top: 32rpx;
  padding: 20rpx 48rpx;
  background: #a8483c;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 16rpx;
}
