page {
  background-color: #eceae8;
  height: 100%;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

.fq-status {
  width: 100%;
  flex-shrink: 0;
  background: #eceae8;
}

.fq-hero {
  flex-shrink: 0;
  padding: 8rpx 36rpx 24rpx;
  background: #eceae8;
}

.fq-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #a8483c;
  letter-spacing: -0.5rpx;
}

.fq-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #8a8580;
  line-height: 1.5;
}

.fq-api-hint {
  display: block;
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: #9e2a2f;
  line-height: 1.45;
  background: rgba(158, 42, 47, 0.08);
  border-radius: 16rpx;
}

.fq-suggest-scroll {
  width: 100%;
  margin-bottom: 28rpx;
  white-space: nowrap;
}

.fq-suggest-row {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 4rpx 8rpx;
}

.fq-suggest-card {
  display: inline-flex;
  flex-direction: column;
  width: 200rpx;
  vertical-align: top;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(42, 34, 32, 0.06);
}

.fq-suggest-card-hover {
  opacity: 0.88;
}

.fq-suggest-img {
  width: 200rpx;
  height: 140rpx;
}

.fq-suggest-name {
  padding: 12rpx 14rpx 16rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #3d2f2c;
  white-space: normal;
  line-height: 1.35;
  min-height: 72rpx;
}

.fq-manual-loc {
  padding-top: 20rpx;
  padding-bottom: 20rpx;
}

.fq-manual-label {
  display: block;
  font-size: 24rpx;
  color: #6b635c;
  margin-bottom: 14rpx;
}

.fq-manual-input {
  font-size: 28rpx;
  color: #3d2f2c;
  padding: 12rpx 0;
}

.publish-btn--busy {
  opacity: 0.85;
  pointer-events: none;
}

.content-scroll {
  flex: 1;
  height: 0;
  box-sizing: border-box;
  overflow: hidden;
}

.scroll-bottom-gap {
  width: 100%;
  box-sizing: content-box;
  height: 380rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.fq-body {
  padding: 0 28rpx 24rpx;
}

.fq-section-label {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #3d2f2c;
  margin-bottom: 16rpx;
}

.fq-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(42, 34, 32, 0.05);
}

.fq-search {
  display: flex;
  align-items: center;
  background: #f5f3f1;
  border-radius: 20rpx;
  padding: 0 22rpx;
  height: 80rpx;
}

.fq-search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  opacity: 0.55;
}

.fq-search-input {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #3d2f2c;
}

.fq-ph {
  color: #a8a29e;
}

.fq-rest-row {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #f0ebe6;
}

.fq-rest-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.fq-rest-info {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
  display: flex;
  flex-direction: column;
}

.fq-rest-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #2a2220;
}

.fq-rest-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8a8580;
}

.fq-rest-clear {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #a8483c;
}

.fq-rest-clear-hover {
  opacity: 0.65;
}

.fq-datetime-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.fq-date-box,
.fq-time-box {
  flex: 1;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 26rpx 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(42, 34, 32, 0.05);
}

.fq-date-text,
.fq-time-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #3d2f2c;
}

.fq-date-ico,
.fq-time-ico {
  font-size: 32rpx;
}

.fq-join-card {
  padding-bottom: 12rpx;
}

.fq-join-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.fq-join-title {
  margin-bottom: 0;
}

.fq-pill {
  padding: 8rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(183, 16, 42, 0.12);
  font-size: 24rpx;
  font-weight: 800;
  color: #a8483c;
}

.fq-slider {
  margin: 20rpx 8rpx 12rpx;
}

.fq-slider-labels {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #9a948f;
  margin-bottom: 28rpx;
}

.fq-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-top: 1rpx solid #f0ebe6;
}

.fq-switch-text {
  flex: 1;
  min-width: 0;
  padding-right: 24rpx;
  display: flex;
  flex-direction: column;
}

.fq-switch-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #3d2f2c;
}

.fq-switch-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8a8580;
  line-height: 1.35;
}

.fq-theme-card {
  padding: 0;
  overflow: hidden;
}

.fq-theme-input {
  padding: 28rpx 24rpx;
  font-size: 28rpx;
  color: #3d2f2c;
  border-bottom: 1rpx solid #f0ebe6;
}

.fq-theme-area {
  min-height: 200rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #3d2f2c;
  line-height: 1.55;
  width: 100%;
  box-sizing: border-box;
}

.publish-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(188rpx + constant(safe-area-inset-bottom));
  bottom: calc(188rpx + env(safe-area-inset-bottom));
  z-index: 99;
  padding: 0 28rpx;
  box-sizing: border-box;
}

.publish-btn {
  height: 96rpx;
  border-radius: 48rpx;
  background: #9e2a2f;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(158, 42, 47, 0.35);
}

.publish-btn-hover {
  opacity: 0.92;
}

.publish-ico {
  margin-right: 12rpx;
  font-size: 34rpx;
}

/* 底部导航（与首页一致） */
.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  box-sizing: border-box;
  min-height: 176rpx;
  background: #ffffff;
  border-radius: 52rpx 52rpx 0 0;
  box-shadow: 0 -8rpx 36rpx rgba(74, 61, 57, 0.08);
  padding: 20rpx 16rpx calc(14rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
}

.tab-bar-inner {
  position: relative;
  width: 100%;
}

.tab-highlight {
  position: absolute;
  left: 0;
  bottom: 2rpx;
  z-index: 0;
  width: 20%;
  height: 124rpx;
  pointer-events: none;
  transition: transform 0.45s cubic-bezier(0.33, 1.12, 0.36, 1);
  will-change: transform;
}

.tab-highlight-inner {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 90%;
  height: 92%;
  max-width: 134rpx;
  transform: translate(-50%, -50%);
  box-sizing: border-box;
  background: linear-gradient(138deg, #e56d64 0%, #c44d44 38%, #b03d36 100%);
  box-shadow: 0 10rpx 28rpx rgba(196, 77, 68, 0.32), 0 0 0 1rpx rgba(255, 255, 255, 0.12) inset;
  animation: tab-flow-morph 4.5s ease-in-out infinite;
}

@keyframes tab-flow-morph {
  0%,
  100% {
    border-radius: 42% 58% 50% 50% / 50% 48% 52% 50%;
    transform: translate(-50%, -50%) scale(1);
  }
  33% {
    border-radius: 54% 46% 44% 56% / 46% 54% 50% 50%;
    transform: translate(-50%, -50%) scale(0.97);
  }
  66% {
    border-radius: 46% 54% 56% 44% / 52% 46% 48% 52%;
    transform: translate(-50%, -50%) scale(1.03);
  }
}

.tab-row {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  min-width: 0;
  padding-bottom: 12rpx;
}

.tab-item--active {
  padding-bottom: 12rpx;
}

.tab-item-hover {
  opacity: 0.88;
}

.tab-ico {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  transition: filter 0.32s ease, transform 0.35s cubic-bezier(0.33, 1.12, 0.36, 1);
}

.tab-item--active .tab-ico {
  transform: translateY(-2rpx);
}

.tab-ico--on {
  filter: brightness(0) invert(1);
}

.tab-txt {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #4a3d39;
  line-height: 1.15;
  transition: color 0.3s ease, transform 0.35s cubic-bezier(0.33, 1.12, 0.36, 1);
}

.tab-item--active .tab-txt {
  transform: translateY(-1rpx);
}

.tab-txt--on {
  color: #ffffff;
}
