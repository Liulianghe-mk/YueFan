page {
  background: #eceae8;
  height: 100%;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #eceae8;
}

.status {
  background: #fdf9f4;
}

.nav {
  display: flex;
  align-items: center;
  padding: 0 8rpx 16rpx;
  background: #fdf9f4;
  border-bottom: 1rpx solid #f0ebe6;
}

.back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #3d2f2c;
}

.back-hover {
  opacity: 0.65;
}

.title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #2a2220;
}

.nav-ph {
  width: 72rpx;
}

.scroll {
  flex: 1;
  height: 0;
  padding: 16rpx 24rpx;
}

.row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  background: #ffffff;
  border-radius: 20rpx;
  border: 1rpx solid #f0ebe6;
}

.row-hover {
  background: #faf8f5;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #2a2220;
}

.chev {
  font-size: 36rpx;
  color: #d4ccc2;
}

.empty {
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-ico {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.empty-txt {
  font-size: 30rpx;
  font-weight: 700;
  color: #3d2f2c;
}

.empty-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #9a948f;
  line-height: 1.5;
}
