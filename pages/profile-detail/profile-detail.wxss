page {
  background-color: #fdf9f4;
  height: 100%;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fdf9f4;
  box-sizing: border-box;
}

.status {
  flex-shrink: 0;
  background: #fdf9f4;
}

.nav {
  flex-shrink: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx;
  background: #fdf9f4;
}

.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 300;
  color: #3d2f2c;
}

.nav-back-hover {
  opacity: 0.65;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #2a2220;
}

.nav-placeholder {
  width: 72rpx;
}

.main {
  flex: 1;
  height: 0;
  box-sizing: border-box;
  padding: 8rpx 28rpx 0;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0 32rpx;
}

.avatar-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 6rpx solid #ffffff;
  box-sizing: border-box;
  box-shadow: 0 12rpx 40rpx rgba(42, 34, 32, 0.12);
}

.verify-badge {
  position: absolute;
  right: 4rpx;
  bottom: 4rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #c9a227, #9a7b1c);
  border: 4rpx solid #fdf9f4;
  display: flex;
  align-items: center;
  justify-content: center;
}

.verify-t {
  font-size: 22rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1;
}

.uname {
  font-size: 40rpx;
  font-weight: 800;
  color: #3d2f2c;
  margin-bottom: 28rpx;
}

.btn-row {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.btn-follow {
  min-width: 200rpx;
  padding: 20rpx 48rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #ffffff;
  text-align: center;
  background: #a8483c;
  box-shadow: 0 8rpx 24rpx rgba(168, 72, 60, 0.28);
}

.btn-follow--on {
  background: #f0ebe4;
  color: #7a726a;
  border: 2rpx solid #e0d8cf;
  box-shadow: none;
}

.btn-msg {
  min-width: 200rpx;
  padding: 20rpx 48rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #5c4338;
  text-align: center;
  background: #ffffff;
  border: 2rpx solid #c9b8a8;
  box-sizing: border-box;
}

.btn-hover {
  opacity: 0.9;
}

.bio {
  font-size: 26rpx;
  line-height: 1.55;
  color: #8a8178;
  text-align: center;
  max-width: 620rpx;
  padding: 0 16rpx;
}

.stats-bar {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  background: #f3ebe3;
  border-radius: 24rpx;
  padding: 32rpx 16rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(42, 34, 32, 0.05);
}

.stat-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.stat-div {
  width: 1rpx;
  background: #e0d5ca;
  margin: 8rpx 0;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #7d4f3a;
}

.stat-label {
  font-size: 24rpx;
  color: #9a928a;
  font-weight: 600;
}

.achieve-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx 24rpx 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(42, 34, 32, 0.07);
}

.achieve-tag {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #e8f4ea;
  margin-bottom: 28rpx;
}

.achieve-tag-ico {
  font-size: 26rpx;
}

.achieve-tag-txt {
  font-size: 26rpx;
  font-weight: 800;
  color: #2d5a3d;
}

.badges-row {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: flex-start;
  gap: 16rpx;
}

.badge-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.badge-ico-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #f0ebe4;
  border: 2rpx solid #e8dfd6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge-ico {
  font-size: 44rpx;
  line-height: 1;
}

.badge-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #6b5a4a;
  text-align: center;
  line-height: 1.35;
}

.sub-list {
  padding-bottom: 16rpx;
}

.sub-row {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 26rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(42, 34, 32, 0.05);
}

.sub-row-hover {
  background: #faf8f5;
}

.sub-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #3d2f2c;
  margin-bottom: 10rpx;
}

.sub-meta {
  font-size: 24rpx;
  color: #9a928a;
}

.sub-empty {
  text-align: center;
  padding: 48rpx 24rpx;
  font-size: 28rpx;
  color: #b5aea5;
}

.scroll-gap {
  height: calc(120rpx + constant(safe-area-inset-bottom));
  height: calc(120rpx + env(safe-area-inset-bottom));
}

.subtab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  padding: 20rpx 16rpx calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -6rpx 24rpx rgba(74, 61, 57, 0.08);
  border-radius: 28rpx 28rpx 0 0;
}

.subtab {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #7a726a;
  padding: 12rpx 8rpx;
  position: relative;
}

.subtab--on {
  color: #a8483c;
}

.subtab--on::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #a8483c;
}
